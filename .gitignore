################################################################################
# ZYRON .gitignore - Comprehensive ignore patterns for professional GitHub repo
################################################################################

# ============================================================================
# DEPENDENCIES
# ============================================================================
node_modules/
.pnp
.pnp.js
package-lock.json

# ============================================================================
# BUILD & RUNTIME ARTIFACTS (CRITICAL - NEVER COMMIT)
# ============================================================================
# Vite Build Output
dist/
dist-ssr/
build/

# Vite Cache
.vite/

# Vercel Deployment
.vercel/
.vercel-build-output/

# ============================================================================
# ENVIRONMENT VARIABLES (CRITICAL SECURITY - NEVER COMMIT)
# ============================================================================
# Real environment variables must NEVER be committed
# Use .env.local for local development (this is gitignored)
.env
.env.local
.env.*.local
.env.production.local

# ============================================================================
# IDE & EDITOR (DO NOT COMMIT)
# ============================================================================
# VS Code
.vscode/
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json

# JetBrains IDEs
.idea/
.idea/workspace.xml
.idea/dictionaries
.idea/inspectionProfiles
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Editor Configuration
*.swp
*.swo
*~

# ============================================================================
# LOGS & DEBUG FILES (NEVER COMMIT)
# ============================================================================
# NPM & Yarn Logs
npm-debug.log*
npm-debug.log
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build Logs
build-log.txt
build_err.txt
build.log
error.log

# All log files
*.log

# ============================================================================
# TEMPORARY & BACKUP FILES (NEVER COMMIT)
# ============================================================================
# Temporary scripts
tmp_*.js
tmp_*.py
tmp_*.jsx
tmp_*.ts
temp_*.*

# Backup & Recovery
*.bak
*.backup
*.orig
*.rej
*~

# Cache files
.cache/
*.tmp
.DS_Store
Thumbs.db

# ============================================================================
# OPERATING SYSTEM (DO NOT COMMIT)
# ============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
*.swp

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
.directory

# ============================================================================
# TESTING & COVERAGE (OPTIONAL - Uncomment if using)
# ============================================================================
coverage/
.nyc_output/
.coverage
htmlcov/

# ============================================================================
# PROJECT SPECIFIC (ZYRON)
# ============================================================================
# SQL Backup/Temp Files (if using local migrations)
*.sql.bak
*.sql.tmp

# Local database files
*.db
*.sqlite
*.sqlite3

# Generated files (if any build tools create them)
dist-types/

# ============================================================================
# DO NOT IGNORE (Keep in repo)
# ============================================================================
# The following ARE important and should NOT be ignored:
# ✓ README.md
# ✓ package.json
# ✓ vite.config.js
# ✓ vercel.json
# ✓ .env.example (with PLACEHOLDERS, not real keys)
# ✓ src/**/*.jsx, src/**/*.js
# ✓ public/**/*
# ✓ docs/**/*
