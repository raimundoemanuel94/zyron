# ============================================================
# ZYRON - Environment Variables Template
# ============================================================
# IMPORTANTE: Este é um template APENAS.
# NUNCA committe valores reais aqui!
# Use .env.local para valores reais (adicionado ao .gitignore)
# ============================================================

# Supabase Configuration
# Get these from: https://app.supabase.com/project/[seu-projeto]/settings/api
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_YOUR_ANON_KEY_HERE

# Google Gemini AI
# Get your key from: https://aistudio.google.com/apikey
# WARNING: Keep this secret! Use .env.local for real value
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Groq AI (Llama 3.3-70B)
# Get your key from: https://console.groq.com
# WARNING: Keep this secret! Use .env.local for real value
VITE_GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
